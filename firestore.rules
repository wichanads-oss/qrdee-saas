# ============================================================
# FIRESTORE SECURITY RULES
# ============================================================
# วางใน Firebase Console → Firestore → Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // เมนู: ลูกค้าอ่านได้, เฉพาะ admin เขียนได้
    match /menus/{menuId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // โต๊ะ: อ่านได้ทุกคน, เขียนเฉพาะ admin
    match /tables/{tableId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ออเดอร์: สร้างได้ทุกคน (ลูกค้า), อ่าน/อัปเดต/ลบเฉพาะ admin
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
